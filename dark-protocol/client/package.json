    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "@project-serum/anchor": "^0.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "bs58": "^5.0.0",
