# ============================================================================
# SOLANA FINANCE SAFETY — never commit these, no exceptions
# ============================================================================

# Solana keypairs — any format, any name
*.json.bak
solana-wallet*.json
my-wallet*.json
default-wallet*.json
dev-wallet*.json
test-wallet*.json
deploy-wallet*.json
*_keypair.json
*-keypair.json
keypair*.json
id.json
# Anchor / solana-test-validator
.anchor/
test-ledger/
# Any raw base58 or base64 key dumps
*.b58
*.b64.key

# ============================================================================
# CLAWD AGENT RUNTIME — generated locally, never version-controlled
# ============================================================================

# TA strategy configs generated by `clawd-agents optimize --ta-config`
ema-cross-*.json
rsi-reversion-*.json
macd-trend-*.json
*-strategy-config.json
ta-config-*.json

# Harness config if generated inside the repo
harness.json
.clawd-harness.json
clawd-harness.json

# Context packs generated by `clawd-agents pack`
*.pack.md
perps-pack.md
*-pack.md
*-context.md
clawd-context-*.md

# Vulcan strategy state (runs/ledgers normally live in ~/.vulcan/ but guard locally too)
.vulcan/
vulcan-runs/
strategy-runs/
*.ledger.json
*.tick-log.json

# Paper trading state
paper-state.json
paper-balance.json
.paper/

# Imperial / perps agent session caches
imperial-session*.json
.imperial/
perps-session*.json
.perps/

# Clawd agent memory / session logs
agent-memory*.json
session-state*.json
.agent-sessions/
*.session.json

# Goals / trade records generated locally
goals-*.json
trade-record-*.json
imp-*.json

# ============================================================================
# API KEYS & TOKENS — belt-and-suspenders beyond .env patterns
# ============================================================================

# Specific secret file patterns (avoid broad *token* which matches code files)
*-secret.json
*.secret.json
auth-token*.json
access-token*.json
bearer-token*.json
refresh-token*.json
oauth-token*.json
*-apikey.json
*-api-key.json
*-private-key.json
*-privatekey.json

# Helius / RPC / provider keys
helius*.json
helius*.env
rpc-config*.json

# ClawdRouter provisioned keys
clawd-key*.json
agent-key*.json
*-agent-key.txt

# ============================================================================
# DATABASE & PERSISTENT STORAGE — local only
# ============================================================================
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
# Convex local state
.convex/

# ============================================================================
# GENERATED ASSETS & REPORTS
# ============================================================================
# Token launch images staged locally
launch-image-*.png
launch-image-*.jpg
launch-image-*.gif

# Audit reports / scan results with potentially sensitive paths
audit-report-*.json
scan-result-*.json
security-scan-*.txt

# pnpm lock is tracked at root; sub-package locks are noise
packages/*/pnpm-lock.yaml
agents/*/pnpm-lock.yaml

# ============================================================================
# RUST / ANCHOR BUILD ARTIFACTS
# NOTE: programs/programs/target/ has ~3000 tracked files that should be
# untracked. Run: git rm -r --cached programs/programs/target/ && git commit
# ============================================================================
programs/programs/target/
programs/target/
**/target/deps/
**/target/debug/
**/target/release/
**/target/sbpf-solana-solana/
.anchor/target/

# ============================================================================
# HUGGING FACE — homebase build dir + token belt-and-suspenders
# The hf/ dir holds local copies of Space repos pushed to huggingface.co.
# Keep it out of the public GitHub mirror entirely.
# ============================================================================
hf/
.huggingface/
huggingface_token*
hf_token*
# Never commit raw HF user access tokens (hf_xxxx...)
**/stored_tokens
clawd-grok
!agents/clawd-grok
clawd-grok
